# Root editorconfig file to enforce C# and Unity coding standards
root = true

[*.cs]
# Use UTF-8 encoding
charset = utf-8-bom

# Indentation and formatting rules
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
newline = lf

# Wrap lines that exceed 80 characters
max_line_length = 80

# Naming Styles
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.interface_style.capitalization = pascal_case
dotnet_naming_style.interface_style.required_prefix = I

dotnet_naming_style.underscore_prefix.capitalization = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

# Naming Symbols
dotnet_naming_symbols.classes_and_enums.applicable_kinds = class, struct, enum, delegate
dotnet_naming_symbols.classes_and_enums.applicable_accessibilities = *

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_symbols.methods.applicable_kinds = method
dotnet_naming_symbols.methods.applicable_accessibilities = *

dotnet_naming_symbols.public_properties_and_fields.applicable_kinds = property, field
dotnet_naming_symbols.public_properties_and_fields.applicable_accessibilities = public, internal

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, protected

dotnet_naming_symbols.locals_and_parameters.applicable_kinds = parameter, local
dotnet_naming_symbols.locals_and_parameters.applicable_accessibilities = *

# Naming rules
dotnet_interfaces_rule.symbols = interfaces
dotnet_interfaces_rule.style = interface_style
dotnet_interfaces_rule.severity = warning

dotnet_naming_rule.classes_rule.symbols = classes_and_enums
dotnet_naming_rule.classes_rule.style = pascal_case
dotnet_naming_rule.classes_rule.severity = warning

dotnet_naming_rule.methods_rule.symbols = methods
dotnet_naming_rule.methods_rule.style = pascal_case
dotnet_naming_rule.methods_rule.severity = warning

dotnet_naming_rule.public_members_rule.symbols = public_properties_and_fields
dotnet_naming_rule.public_members_rule.style = pascal_case
dotnet_naming_rule.public_members_rule.severity = warning

dotnet_naming_rule.private_fields_rule.symbols = private_fields
dotnet_naming_rule.private_fields_rule.style = underscore_prefix
dotnet_naming_rule.private_fields_rule.severity = warning

dotnet_naming_rule.locals_rule.symbols = locals_and_parameters
dotnet_naming_rule.locals_rule.style = camel_case
dotnet_naming_rule.locals_rule.severity = warning

